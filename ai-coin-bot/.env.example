# AI Coin Bot Environment Variables
# ==================================
# Copy this file to .env and fill in your values

# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Solana Wallet Private Key (required for execution)
# Can be base58 encoded string or JSON array format
SOLANA_PRIVATE_KEY=your-private-key-here

# Your PumpFun Token Address (required)
COIN_ADDRESS=your-token-mint-address-here

# Solana RPC URL (optional, defaults to public RPC)
# Recommended: Use a private RPC like Helius, QuickNode, or Triton
RPC_URL=https://api.mainnet-beta.solana.com

# Optional: Birdeye API Key for better OHLCV data
BIRDEYE_API_KEY=

# Optional: Discord Webhook for notifications
DISCORD_WEBHOOK_URL=

# Optional: Telegram Bot for notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
